{
  "name": "cj-nantianmen",
  "version": "0.2.12",
  "description": "Nantianmen LLM Proxy Gateway - Desktop UI",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && npx @electron/rebuild -m ../server -w better-sqlite3 -f && npx electron-builder --win --x64 && node -e \"const fs=require('fs'),p=require('path');fs.mkdirSync('../releases',{recursive:true});fs.readdirSync('../temp').filter(f=>f.startsWith('nantianmen-')&&(f.endsWith('.exe')||f.endsWith('.7z'))).forEach(f=>fs.copyFileSync(p.join('../temp',f),p.join('../releases',f)));fs.readdirSync('../temp').filter(f=>f.startsWith('nantianmen-')).forEach(f=>fs.unlinkSync(p.join('../temp',f)));fs.rmSync('../temp/win-unpacked',{recursive:true,force:true})\"",
    "electron:build:mac": "vite build && npx @electron/rebuild -m ../server -w better-sqlite3 -f && npx electron-builder --mac"
  },
  "build": {
    "appId": "com.jiangcat.nantianmen",
    "productName": "Nantianmen",
    "directories": {
      "output": "../temp",
      "buildResources": "."
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "nantianmen-${version}-win-${arch}.${ext}",
      "signAndEditExecutable": false,
      "icon": "nantianmen.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "artifactName": "nantianmen-${version}-mac-${arch}.${ext}",
      "icon": "nantianmen-logo.png"
    },
    "linux": {
      "icon": "nantianmen-logo.png"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "nantianmen.ico",
      "nantianmen-logo.png"
    ],
    "extraResources": [
      {
        "from": "../server",
        "to": "server",
        "filter": [
          "**/*",
          "!**/.venv/**",
          "!**/node_modules/.cache/**"
        ]
      }
    ]
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "vite": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0",
    "cross-env": "^7.0.3"
  }
}
